# ============================================================
#  AI-Genius – Environment Variables  (.env.example)
#  Copy this file to .env and fill in your own values.
#  NEVER commit the real .env file to version control.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# JWT Secrets  –  use long, random strings in production
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# Token expiry
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=your_cookie_secret_here

# Database URI (uncomment when using MongoDB)
# MONGO_URI=mongodb://localhost:27017/ai-genius

# Database URI (uncomment when using PostgreSQL)
# PG_URI=postgresql://user:password@localhost:5432/ai_genius
